#version 460
#extension GL_GOOGLE_include_directive : require

#include "wavefront_common.glsl"

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(set = 0, binding = 0, std430) readonly buffer HitQueueBuffer {
    WavefrontQueueHeader header;
    WavefrontHit records[];
} hit_queue;

layout(set = 0, binding = 1, std430) readonly buffer DepthNormalBuffer {
    uvec4 depth_normal_buffer[];
};

layout(set = 0, binding = 2, std430) readonly buffer EntityIdBuffer {
    uint entity_id_buffer[];
};

layout(set = 0, binding = 3, std430) buffer ValidationBuffer {
    uvec4 counters;
    uvec4 metrics;
} validation;

layout(push_constant) uniform PushConstants {
    uint width;
    uint height;
    float depth_epsilon;
    float normal_dot_threshold;
} pc;

vec2 unpack_snorm2x16(uint packedValue) {
    ivec2 quantized = ivec2(int(packedValue & 0xffffu), int((packedValue >> 16u) & 0xffffu));
    if (quantized.x >= 32768) {
        quantized.x -= 65536;
    }
    if (quantized.y >= 32768) {
        quantized.y -= 65536;
    }
    return clamp(vec2(quantized) / 32767.0, vec2(-1.0), vec2(1.0));
}

vec3 decode_octahedral_normal(uint packedValue) {
    vec2 f = unpack_snorm2x16(packedValue);
    vec3 n = vec3(f.x, f.y, 1.0 - abs(f.x) - abs(f.y));
    float t = clamp(-n.z, 0.0, 1.0);
    n.x += n.x >= 0.0 ? -t : t;
    n.y += n.y >= 0.0 ? -t : t;
    return normalize(n);
}

uint pack_unorm2x16(vec2 v) {
    uint x = uint(round(clamp(v.x, 0.0, 1.0) * 65535.0));
    uint y = uint(round(clamp(v.y, 0.0, 1.0) * 65535.0));
    return x | (y << 16u);
}

uint pack_snorm2x16(vec2 v) {
    return pack_unorm2x16(v * 0.5 + vec2(0.5));
}

uint encode_octahedral_normal(vec3 n) {
    float denom = abs(n.x) + abs(n.y) + abs(n.z) + 1e-8;
    vec2 p = n.xy / denom;
    if (n.z < 0.0) {
        p = (vec2(1.0) - abs(p.yx)) * vec2(p.x >= 0.0 ? 1.0 : -1.0, p.y >= 0.0 ? 1.0 : -1.0);
    }
    return pack_snorm2x16(p);
}

bool packed_normal_close(uint a, uint b) {
    ivec2 pa = ivec2(int(a & 0xffffu), int((a >> 16u) & 0xffffu));
    ivec2 pb = ivec2(int(b & 0xffffu), int((b >> 16u) & 0xffffu));
    ivec2 delta = abs(pa - pb);
    return delta.x <= 1 && delta.y <= 1;
}

void main() {
    uvec2 pixel = gl_GlobalInvocationID.xy;
    if (pixel.x >= pc.width || pixel.y >= pc.height) {
        return;
    }

    uint pixel_index = pixel.y * pc.width + pixel.x;
    if (pixel_index == 0u) {
        validation.metrics.y = pc.width * pc.height;
        validation.metrics.z = hit_queue.header.counters.x;
    }
    if (pixel_index >= hit_queue.header.counters.y) {
        return;
    }

    WavefrontHit hit = hit_queue.records[pixel_index];
    bool waveHit = hit.barycentrics_hit_kind.w > 0.5;
    bool megaHit = entity_id_buffer[pixel_index] != 0xffffffffu;
    atomicAdd(validation.counters.x, 1u);

    if (waveHit != megaHit) {
        atomicAdd(validation.counters.y, 1u);
        return;
    }
    if (!waveHit) {
        return;
    }

    if (hit.material_instance_primitive.y != entity_id_buffer[pixel_index]) {
        atomicAdd(validation.counters.z, 1u);
    }

    float megaDepth = uintBitsToFloat(depth_normal_buffer[pixel_index].x);
    float waveDepth = hit.position_t.w;
    float tolerance = max(pc.depth_epsilon, abs(megaDepth) * 0.001);
    if (abs(waveDepth - megaDepth) > tolerance) {
        atomicAdd(validation.counters.w, 1u);
    }

    vec3 waveNormal = normalize(hit.normal_roughness.xyz);
    if (!packed_normal_close(encode_octahedral_normal(waveNormal), depth_normal_buffer[pixel_index].y)) {
        atomicAdd(validation.metrics.x, 1u);
    }
}
