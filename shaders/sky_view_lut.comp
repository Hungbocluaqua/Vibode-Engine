#version 450
#extension GL_GOOGLE_include_directive : require

#include "atmosphere_phase.glsl"

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(set = 0, binding = 0) uniform texture2D transmittance_lut;
layout(set = 0, binding = 1) uniform sampler atmosphere_sampler;
layout(set = 0, binding = 2, rgba16f) uniform writeonly image2D sky_view_lut;
layout(set = 0, binding = 3) uniform texture2D multi_scatter_lut;

layout(push_constant) uniform SkyViewParams {
    vec4 planet_radius_atmosphere_radius;
    vec4 rayleigh_scattering;
    vec4 mie_scattering_anisotropy;
    vec4 absorption_ground_albedo;
    vec4 scale_heights;
    vec4 sun_elevation_intensity;
} params;

vec3 sky_sun_direction() {
    float elevation = clamp(params.sun_elevation_intensity.x, -0.20, 1.45);
    float azimuth = params.sun_elevation_intensity.z;
    float cosElevation = cos(elevation);
    return normalize(vec3(cosElevation * sin(azimuth), sin(elevation), cosElevation * cos(azimuth)));
}

vec3 sample_transmittance(float heightMeters, float mu) {
    float atmosphereHeight = max(params.planet_radius_atmosphere_radius.y - params.planet_radius_atmosphere_radius.x, 1.0);
    vec2 uv = vec2(clamp((mu + 0.20) / 1.20, 0.0, 1.0), clamp(heightMeters / atmosphereHeight, 0.0, 1.0));
    return texture(sampler2D(transmittance_lut, atmosphere_sampler), uv).rgb;
}

vec3 sample_multi_scatter(float viewMu, float sunMu) {
    vec2 uv = vec2(clamp((viewMu + 0.20) / 1.20, 0.0, 1.0), clamp((sunMu + 0.20) / 1.20, 0.0, 1.0));
    return texture(sampler2D(multi_scatter_lut, atmosphere_sampler), uv).rgb;
}

float sky_air_mass(float cosZenith) {
    float y = clamp(cosZenith, -0.08, 1.0);
    return 1.0 / max(y + 0.15 * pow(max(1.08 - y, 0.0), -1.253), 0.06);
}

float saturate(float v) {
    return clamp(v, 0.0, 1.0);
}

float sky_horizon_visibility(vec3 dir, float width) {
    float viewY = normalize(dir).y;
    return smoothstep(-width, width, viewY + 0.001);
}

vec3 unreal_sky_grade(vec3 dir, vec3 physicalSky) {
    vec3 viewDir = normalize(dir);
    vec3 sunDir = sky_sun_direction();
    float viewY = viewDir.y;
    float sunUp = clamp(sunDir.y, -0.12, 1.0);
    float sunVisibility = smoothstep(-0.08, 0.08, sunUp);
    float lowSun = 1.0 - smoothstep(0.18, 0.82, sunUp);
    float sunset = 1.0 - smoothstep(0.02, 0.34, sunUp);
    float horizonVisibility = sky_horizon_visibility(viewDir, 0.010);
    float sunHorizon = sky_horizon_visibility(sunDir, 0.016);
    float horizon = pow(1.0 - smoothstep(-0.02, 0.62, viewY), 1.65);
    float cosTheta = clamp(dot(viewDir, sunDir), -1.0, 1.0);

    vec3 dayZenith = vec3(0.32, 0.50, 0.78);
    vec3 dayHorizon = vec3(0.74, 0.84, 0.96);
    vec3 lowZenith = vec3(0.43, 0.47, 0.63);
    vec3 sunsetZenith = vec3(0.36, 0.34, 0.50);
    vec3 lowHorizon = vec3(1.0, 0.72, 0.46);
    vec3 sunsetHorizon = vec3(1.0, 0.52, 0.30);
    vec3 zenithColor = mix(dayZenith, mix(lowZenith, sunsetZenith, sunset), lowSun);
    vec3 horizonColor = mix(dayHorizon, mix(lowHorizon, sunsetHorizon, sunset), lowSun);
    vec3 palette = mix(zenithColor, horizonColor, horizon);

    float physicalLum = dot(max(physicalSky, vec3(0.0)), vec3(0.2126, 0.7152, 0.0722));
    vec3 sky = palette * (0.55 + 0.28 * saturate(physicalLum)) + physicalSky * 0.13;

    float haloTight = pow(saturate(cosTheta), mix(42.0, 16.0, lowSun));
    float haloWide = pow(saturate(cosTheta), mix(10.0, 5.5, lowSun));
    vec3 haloColor = mix(vec3(1.0, 0.94, 0.78), vec3(1.0, 0.62, 0.34), lowSun);
    sky += haloColor * sunVisibility * sunHorizon * horizonVisibility * (haloTight * 0.26 + haloWide * 0.045);

    return max(sky * params.sun_elevation_intensity.y * horizonVisibility, vec3(0.0));
}

vec3 analytical_sky_fallback(vec3 dir) {
    vec3 viewDir = normalize(dir);
    vec3 sunDir = sky_sun_direction();
    float viewUp = clamp(viewDir.y, -0.08, 1.0);
    float sunUp = clamp(sunDir.y, -0.08, 1.0);
    float cosTheta = clamp(dot(viewDir, sunDir), -1.0, 1.0);
    float sunVisibility = smoothstep(-0.06, 0.08, sunUp);
    float horizon = pow(1.0 - clamp(viewUp, 0.0, 1.0), 2.0);
    vec3 rayleighBeta = vec3(0.170, 0.398, 0.970);
    vec3 mieBeta = vec3(0.82, 0.74, 0.62);
    vec3 transmittance = exp(-(rayleighBeta * 0.30 + mieBeta * 0.08) * (sky_air_mass(viewUp) + sky_air_mass(sunUp) * 0.65));
    vec3 sunsetScatter = vec3(1.0, 0.42, 0.12) * smoothstep(-0.08, 0.18, horizon) * (1.0 - smoothstep(0.05, 0.55, sunUp));
    vec3 rayleigh = rayleighBeta * atmosphere_rayleigh_phase(cosTheta) * (0.55 + horizon * 0.75);
    vec3 mie = mieBeta * atmosphere_mie_phase(cosTheta, 0.78) * (0.05 + horizon * 0.26);
    vec3 night = vec3(0.004, 0.006, 0.012) * smoothstep(-0.25, -0.05, sunUp);
    vec3 physicalSky = ((rayleigh + mie + sunsetScatter * 0.10) * transmittance * sunVisibility * 3.8 + night);
    return unreal_sky_grade(viewDir, physicalSky);
}

vec3 sky_extinction_at_height(float heightMeters) {
    float rayleighDensity = exp(-heightMeters / max(params.scale_heights.x, 1.0));
    float mieDensity = exp(-heightMeters / max(params.scale_heights.y, 1.0));
    float ozoneDensity = max(1.0 - abs(heightMeters - params.scale_heights.z) / max(params.scale_heights.w, 1.0), 0.0);
    return params.rayleigh_scattering.xyz * rayleighDensity +
        params.mie_scattering_anisotropy.xyz * mieDensity +
        params.absorption_ground_albedo.xyz * ozoneDensity;
}

vec3 integrate_sky(vec3 viewDir) {
    vec3 sunDir = sky_sun_direction();
    float sunUp = sunDir.y;
    float sunVisibility = smoothstep(-0.06, 0.08, sunUp);
    if (sunVisibility <= 0.0) {
        return vec3(0.001, 0.0015, 0.003) * params.sun_elevation_intensity.y;
    }

    vec3 origin = vec3(0.0, params.planet_radius_atmosphere_radius.x + 1.7, 0.0);
    float tNear;
    float tFar;
    if (!atmosphere_ray_sphere_intersection(origin, viewDir, params.planet_radius_atmosphere_radius.y, tNear, tFar)) {
        return vec3(0.0);
    }
    float groundNear;
    float groundFar;
    if (atmosphere_ray_sphere_intersection(origin, viewDir, params.planet_radius_atmosphere_radius.x, groundNear, groundFar)) {
        tFar = min(tFar, groundNear);
    }
    if (tFar <= 0.0) {
        return vec3(0.0);
    }

    const int sampleCount = 24;
    float segmentLength = min(tFar, 120000.0) / float(sampleCount);
    vec3 luminance = vec3(0.0);
    for (int i = 0; i < sampleCount; ++i) {
        float t = (float(i) + 0.5) * segmentLength;
        vec3 samplePos = origin + viewDir * t;
        float height = max(length(samplePos) - params.planet_radius_atmosphere_radius.x, 0.0);
        vec3 up = normalize(samplePos);
        float viewMu = dot(viewDir, up);
        float sunMu = dot(sunDir, up);
        float cosTheta = dot(viewDir, sunDir);
        vec3 viewTransmittance = sample_transmittance(height, viewMu);
        vec3 sunTransmittance = sample_transmittance(height, sunMu);
        float rayleighDensity = exp(-height / max(params.scale_heights.x, 1.0));
        float mieDensity = exp(-height / max(params.scale_heights.y, 1.0));
        vec3 scattering = params.rayleigh_scattering.xyz * rayleighDensity * atmosphere_rayleigh_phase(cosTheta) +
            params.mie_scattering_anisotropy.xyz * mieDensity * atmosphere_mie_phase(cosTheta, params.mie_scattering_anisotropy.w);
        scattering += sample_multi_scatter(viewMu, sunMu) * 0.000012;
        vec3 extinction = sky_extinction_at_height(height);
        luminance += viewTransmittance * sunTransmittance * scattering * exp(-extinction * t * 0.25) * segmentLength;
    }
    vec3 sunsetTint = mix(vec3(1.0, 0.62, 0.38), vec3(1.0), smoothstep(0.02, 0.40, sunUp));
    return luminance * sunsetTint * params.sun_elevation_intensity.y * 9.0 * sunVisibility;
}

vec3 direction_from_latlong(vec2 uv) {
    float phi = (uv.x - 0.5) * 6.28318530718;
    float lat = (uv.y - 0.5) * 3.14159265359;
    float cosLat = cos(lat);
    return normalize(vec3(cosLat * cos(phi), sin(lat), cosLat * sin(phi)));
}

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    ivec2 dims = imageSize(sky_view_lut);
    if (pixel.x >= dims.x || pixel.y >= dims.y) {
        return;
    }

    vec2 uv = (vec2(pixel) + vec2(0.5)) / vec2(dims);
    vec3 dir = direction_from_latlong(uv);
    vec3 sky = integrate_sky(dir);
    if (dot(sky, vec3(0.2126, 0.7152, 0.0722)) <= 1.0e-5) {
        sky = analytical_sky_fallback(dir);
    } else {
        sky = unreal_sky_grade(dir, sky);
    }
    imageStore(sky_view_lut, pixel, vec4(max(sky, vec3(0.0)), 1.0));
}
