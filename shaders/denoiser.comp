#version 450
#extension GL_GOOGLE_include_directive : require

#include "temporal_common.glsl"

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

#ifndef RTV_DENOISER_SHARED_TILE
#define RTV_DENOISER_SHARED_TILE 1
#endif

layout(set = 0, binding = 0, rgba16f) readonly uniform image2D input_color;
layout(set = 0, binding = 1, std430) readonly buffer InputDepthNormal { uvec4 input_depth_normal[]; };
layout(set = 0, binding = 2, std430) readonly buffer InputVariance { uint input_variance[]; };
layout(set = 0, binding = 3, rgba16f) readonly uniform image2D history_color;
layout(set = 0, binding = 4, rgba16f) writeonly uniform image2D output_denoised;

layout(set = 0, binding = 5, std140) uniform DenoiserParams {
    uint enabled;
    float strength;
    uint frame_count;
    uint width;
    uint height;
    uint atrous_iterations;
    uint debug_view;
    uint reset_history;
    uint frames_since_reset;
} params;

layout(set = 0, binding = 6, std430) readonly buffer WorldPosition { uvec2 world_position[]; };
layout(set = 0, binding = 7, std430) readonly buffer PrevWorldPosition { uvec2 prev_world_position[]; };
layout(set = 0, binding = 9, std430) readonly buffer VelocityBuffer { uint velocity_buffer[]; };
struct PathDataRecord {
    vec4 direct_diffuse;
    vec4 direct_specular;
    vec4 indirect_diffuse;
    vec4 indirect_specular;
    vec4 albedo_roughness_hit_confidence;
};
layout(set = 0, binding = 10, std430) readonly buffer PathDataBuffer { PathDataRecord path_data_buffer[]; };
layout(set = 0, binding = 11, rgba16f) readonly uniform image2D diffuse_history;
layout(set = 0, binding = 12, rgba16f) readonly uniform image2D specular_history;
layout(set = 0, binding = 13, rgba16f) writeonly uniform image2D output_diffuse_history;
layout(set = 0, binding = 14, rgba16f) writeonly uniform image2D output_specular_history;

layout(set = 0, binding = 15, rg16f) readonly uniform image2D direct_diffuse_moments;
layout(set = 0, binding = 16, rg16f) readonly uniform image2D direct_specular_moments;
layout(set = 0, binding = 17, rg16f) readonly uniform image2D indirect_diffuse_moments;
layout(set = 0, binding = 18, rg16f) readonly uniform image2D indirect_specular_moments;
layout(set = 0, binding = 19, rgba16ui) readonly uniform uimage2D history_length;
layout(set = 0, binding = 20, rgba16f) readonly uniform image2D moment_debug;

layout(set = 0, binding = 8, std140) uniform PrevCamera {
    mat4 view_proj;
    mat4 inv_view_proj;
    mat4 prev_view_proj;
    vec4 current_pos;
    vec4 prev_pos;
    vec4 jitter;
} prev_camera;

float luminance(vec3 c) {
    return dot(c, vec3(0.2126, 0.7152, 0.0722));
}

#if RTV_DENOISER_SHARED_TILE
const int DENOISER_TILE_RADIUS = 2;
const int DENOISER_LOCAL_SIZE_X = 16;
const int DENOISER_LOCAL_SIZE_Y = 16;
const int DENOISER_SHARED_SIZE_X = DENOISER_LOCAL_SIZE_X + DENOISER_TILE_RADIUS * 2;
const int DENOISER_SHARED_SIZE_Y = DENOISER_LOCAL_SIZE_Y + DENOISER_TILE_RADIUS * 2;
const int DENOISER_SHARED_COUNT = DENOISER_SHARED_SIZE_X * DENOISER_SHARED_SIZE_Y;

shared vec4 shared_color_tile[DENOISER_SHARED_COUNT];
shared uvec4 shared_depth_normal_tile[DENOISER_SHARED_COUNT];

int denoiser_shared_index(ivec2 tileCoords) {
    return tileCoords.y * DENOISER_SHARED_SIZE_X + tileCoords.x;
}
#endif

float atrous_kernel_weight(int offsetValue) {
    if (offsetValue == 0) {
        return 0.375;
    }
    if (abs(offsetValue) == 1) {
        return 0.25;
    }
    return 0.0625;
}

bool is_surface_depth(float depth) {
    return depth < 1.0e9;
}

vec2 unpack_unorm2x16(uint packedValue) {
    return vec2(float(packedValue & 0xffffu), float((packedValue >> 16u) & 0xffffu)) / 65535.0;
}

vec2 unpack_snorm2x16(uint packedValue) {
    return unpack_unorm2x16(packedValue) * 2.0 - vec2(1.0);
}

vec3 decode_octahedral_normal(uint packedValue) {
    vec2 f = unpack_snorm2x16(packedValue);
    vec3 n = vec3(f.x, f.y, 1.0 - abs(f.x) - abs(f.y));
    float t = clamp(-n.z, 0.0, 1.0);
    n.x += n.x >= 0.0 ? -t : t;
    n.y += n.y >= 0.0 ? -t : t;
    return normalize(n);
}

vec4 decode_depth_normal(uvec4 packedValue) {
    return vec4(uintBitsToFloat(packedValue.x), decode_octahedral_normal(packedValue.y));
}

float decode_variance(uint packedValue) {
    return float(packedValue & 0xffffu) / 65535.0 * 64.0;
}

vec3 decode_world_position(uvec2 packedValue, vec3 origin) {
    if (packedValue.x == 0u && packedValue.y == 0u) {
        return vec3(0.0, 1.0e10, 0.0);
    }
    vec2 xy = unpack_snorm2x16(packedValue.x);
    float z = unpack_snorm2x16(packedValue.y).x;
    return origin + vec3(xy.x, xy.y, z) * 8.0;
}

vec3 reconstruct_current_world_position(ivec2 coords, float depth, ivec2 dims) {
    if (!is_surface_depth(depth)) {
        return vec3(0.0, 1.0e10, 0.0);
    }

    vec2 uv = (vec2(coords) + vec2(0.5)) / vec2(dims);
    vec2 ndc = uv * 2.0 - 1.0;
    vec4 world_far = prev_camera.inv_view_proj * vec4(ndc, 1.0, 1.0);
    if (abs(world_far.w) <= 1.0e-6) {
        return decode_world_position(world_position[uint(coords.y) * uint(dims.x) + uint(coords.x)], prev_camera.current_pos.xyz);
    }

    vec3 ray_dir = world_far.xyz / world_far.w - prev_camera.current_pos.xyz;
    if (dot(ray_dir, ray_dir) <= 1.0e-8) {
        return decode_world_position(world_position[uint(coords.y) * uint(dims.x) + uint(coords.x)], prev_camera.current_pos.xyz);
    }

    return prev_camera.current_pos.xyz + normalize(ray_dir) * depth;
}

vec2 project_world_to_pixels(mat4 viewProj, vec3 worldPos, ivec2 dims) {
    vec4 clip = viewProj * vec4(worldPos, 1.0);
    if (clip.w <= 0.0) {
        return vec2(-1.0);
    }
    vec3 ndc = clip.xyz / clip.w;
    if (ndc.z < 0.0 || ndc.z > 1.0001) {
        return vec2(-1.0);
    }
    return vec2(
        (ndc.x * 0.5 + 0.5) * float(dims.x) - 0.5,
        (ndc.y * 0.5 + 0.5) * float(dims.y) - 0.5);
}

vec2 project_world_to_history(vec3 worldPos, ivec2 dims) {
    return project_world_to_pixels(prev_camera.prev_view_proj, worldPos, dims);
}

vec2 reproject_history(ivec2 coords, vec3 worldPos, ivec2 dims) {
    return project_world_to_history(worldPos, dims);
}

vec2 reproject_sky_history(ivec2 coords, ivec2 dims) {
    vec2 uv = (vec2(coords) + vec2(0.5)) / vec2(dims);
    vec2 ndc = uv * 2.0 - 1.0;
    vec4 world_far = prev_camera.inv_view_proj * vec4(ndc, 1.0, 1.0);
    if (abs(world_far.w) <= 1.0e-6) {
        return vec2(-1.0);
    }

    vec3 current_far = world_far.xyz / world_far.w;
    vec3 sky_dir = current_far - prev_camera.current_pos.xyz;
    if (dot(sky_dir, sky_dir) <= 1.0e-8) {
        return vec2(-1.0);
    }

    return project_world_to_history(prev_camera.prev_pos.xyz + normalize(sky_dir) * 512.0, dims);
}

vec3 bilinear_history_color(vec2 historyPos, ivec2 dims) {
    ivec2 base = ivec2(floor(historyPos));
    vec2 fracValue = fract(historyPos);
    ivec2 p00 = clamp(base, ivec2(0), dims - ivec2(1));
    if (fracValue.x <= 1.0e-5 && fracValue.y <= 1.0e-5) {
        return imageLoad(history_color, p00).rgb;
    }
    ivec2 p10 = clamp(base + ivec2(1, 0), ivec2(0), dims - ivec2(1));
    ivec2 p01 = clamp(base + ivec2(0, 1), ivec2(0), dims - ivec2(1));
    ivec2 p11 = clamp(base + ivec2(1, 1), ivec2(0), dims - ivec2(1));
    vec3 c00 = imageLoad(history_color, p00).rgb;
    vec3 c10 = imageLoad(history_color, p10).rgb;
    vec3 c01 = imageLoad(history_color, p01).rgb;
    vec3 c11 = imageLoad(history_color, p11).rgb;
    return mix(mix(c00, c10, fracValue.x), mix(c01, c11, fracValue.x), fracValue.y);
}

vec3 bilinear_diffuse_history_color(vec2 historyPos, ivec2 dims) {
    ivec2 base = ivec2(floor(historyPos));
    vec2 fracValue = fract(historyPos);
    ivec2 p00 = clamp(base, ivec2(0), dims - ivec2(1));
    if (fracValue.x <= 1.0e-5 && fracValue.y <= 1.0e-5) {
        return imageLoad(diffuse_history, p00).rgb;
    }
    ivec2 p10 = clamp(base + ivec2(1, 0), ivec2(0), dims - ivec2(1));
    ivec2 p01 = clamp(base + ivec2(0, 1), ivec2(0), dims - ivec2(1));
    ivec2 p11 = clamp(base + ivec2(1, 1), ivec2(0), dims - ivec2(1));
    vec3 c00 = imageLoad(diffuse_history, p00).rgb;
    vec3 c10 = imageLoad(diffuse_history, p10).rgb;
    vec3 c01 = imageLoad(diffuse_history, p01).rgb;
    vec3 c11 = imageLoad(diffuse_history, p11).rgb;
    return mix(mix(c00, c10, fracValue.x), mix(c01, c11, fracValue.x), fracValue.y);
}

vec3 bilinear_specular_history_color(vec2 historyPos, ivec2 dims) {
    ivec2 base = ivec2(floor(historyPos));
    vec2 fracValue = fract(historyPos);
    ivec2 p00 = clamp(base, ivec2(0), dims - ivec2(1));
    if (fracValue.x <= 1.0e-5 && fracValue.y <= 1.0e-5) {
        return imageLoad(specular_history, p00).rgb;
    }
    ivec2 p10 = clamp(base + ivec2(1, 0), ivec2(0), dims - ivec2(1));
    ivec2 p01 = clamp(base + ivec2(0, 1), ivec2(0), dims - ivec2(1));
    ivec2 p11 = clamp(base + ivec2(1, 1), ivec2(0), dims - ivec2(1));
    vec3 c00 = imageLoad(specular_history, p00).rgb;
    vec3 c10 = imageLoad(specular_history, p10).rgb;
    vec3 c01 = imageLoad(specular_history, p01).rgb;
    vec3 c11 = imageLoad(specular_history, p11).rgb;
    return mix(mix(c00, c10, fracValue.x), mix(c01, c11, fracValue.x), fracValue.y);
}

vec3 bilinear_prev_world(vec2 historyPos, ivec2 dims) {
    ivec2 base = ivec2(floor(historyPos));
    vec2 fracValue = fract(historyPos);
    ivec2 p00 = clamp(base, ivec2(0), dims - ivec2(1));
    if (fracValue.x <= 1.0e-5 && fracValue.y <= 1.0e-5) {
        uint i00 = uint(p00.y) * uint(dims.x) + uint(p00.x);
        return decode_world_position(prev_world_position[i00], prev_camera.prev_pos.xyz);
    }
    ivec2 p10 = clamp(base + ivec2(1, 0), ivec2(0), dims - ivec2(1));
    ivec2 p01 = clamp(base + ivec2(0, 1), ivec2(0), dims - ivec2(1));
    ivec2 p11 = clamp(base + ivec2(1, 1), ivec2(0), dims - ivec2(1));
    uint i00 = uint(p00.y) * uint(dims.x) + uint(p00.x);
    uint i10 = uint(p10.y) * uint(dims.x) + uint(p10.x);
    uint i01 = uint(p01.y) * uint(dims.x) + uint(p01.x);
    uint i11 = uint(p11.y) * uint(dims.x) + uint(p11.x);
    vec3 w00 = decode_world_position(prev_world_position[i00], prev_camera.prev_pos.xyz);
    vec3 w10 = decode_world_position(prev_world_position[i10], prev_camera.prev_pos.xyz);
    vec3 w01 = decode_world_position(prev_world_position[i01], prev_camera.prev_pos.xyz);
    vec3 w11 = decode_world_position(prev_world_position[i11], prev_camera.prev_pos.xyz);
    return mix(mix(w00, w10, fracValue.x), mix(w01, w11, fracValue.x), fracValue.y);
}

void main() {
    ivec2 coords = ivec2(gl_GlobalInvocationID.xy);
    ivec2 dims = imageSize(input_color);
    bool in_bounds = coords.x < dims.x && coords.y < dims.y;

#if RTV_DENOISER_SHARED_TILE
    ivec2 workgroup_origin = ivec2(gl_WorkGroupID.xy) * ivec2(DENOISER_LOCAL_SIZE_X, DENOISER_LOCAL_SIZE_Y);
    uint local_linear = gl_LocalInvocationID.y * gl_WorkGroupSize.x + gl_LocalInvocationID.x;
    uint local_count = gl_WorkGroupSize.x * gl_WorkGroupSize.y;
    ivec2 max_coords = max(dims - ivec2(1), ivec2(0));
    for (uint i = local_linear; i < uint(DENOISER_SHARED_COUNT); i += local_count) {
        ivec2 tile_coords = ivec2(int(i) % DENOISER_SHARED_SIZE_X, int(i) / DENOISER_SHARED_SIZE_X);
        ivec2 sample_coords = clamp(workgroup_origin + tile_coords - ivec2(DENOISER_TILE_RADIUS), ivec2(0), max_coords);
        uint sample_index = uint(sample_coords.y) * uint(dims.x) + uint(sample_coords.x);
        shared_color_tile[i] = imageLoad(input_color, sample_coords);
        shared_depth_normal_tile[i] = input_depth_normal[sample_index];
    }
    barrier();
#endif

    if (!in_bounds) {
        return;
    }

    vec3 center_color = imageLoad(input_color, coords).rgb;
    uint pixel_index = uint(coords.y) * uint(dims.x) + uint(coords.x);
    vec4 center_dn = decode_depth_normal(input_depth_normal[pixel_index]);
    float center_depth = center_dn.r;
    vec3 center_normal = center_dn.gba;
    float center_roughness = clamp(uintBitsToFloat(input_depth_normal[pixel_index].z), 0.0, 1.0);
    float center_var = decode_variance(input_variance[pixel_index]);

    if (params.enabled == 0u && params.debug_view == 0u) {
        imageStore(output_denoised, coords, vec4(center_color, 1.0));
        return;
    }

    PathDataRecord path_data = path_data_buffer[pixel_index];
    float center_primary_hit_distance = path_data.direct_specular.a;
    float center_secondary_hit_distance = path_data.indirect_specular.a;
    float center_primary_hit_normalized = temporal_normalized_hit_distance(center_primary_hit_distance);
    float center_secondary_hit_normalized = temporal_normalized_hit_distance(center_secondary_hit_distance);
    float specular_lum = luminance(path_data.direct_specular.rgb + path_data.indirect_specular.rgb);
    float diffuse_lum = luminance(path_data.direct_diffuse.rgb + path_data.indirect_diffuse.rgb);
    float specular_signal = clamp(specular_lum / max(specular_lum + diffuse_lum, 1.0e-4), 0.0, 1.0);
    float emissive_lum = max(path_data.direct_diffuse.a, 0.0);
    float emissive_log = log2(max(emissive_lum, 0.0) + 1.0) / 8.0;
    float emissive_signal = smoothstep(0.10, 0.55, emissive_log);
    float distance_kernel_bias = center_roughness * smoothstep(0.12, 0.55, center_primary_hit_normalized);

    float center_lum = luminance(center_color);
    float var_factor = sqrt(max(center_var, 0.0));
    vec2 velocity_pixels = temporal_unpack_velocity_pixels(velocity_buffer[pixel_index], 64.0);
    float motion_filter_boost = smoothstep(0.75, 12.0, length(velocity_pixels));
    float motion_history_available = params.reset_history == 0u ? motion_filter_boost : 0.0;
    float inv_strength = 1.0 / max(params.strength, 0.001);
    float capped_var = min(var_factor, 0.7);
    float sigma_color = (0.18 + capped_var * 1.2) * inv_strength * mix(1.0, 1.65, motion_filter_boost);
    float sigma_depth = (0.12 + var_factor * 0.45) * inv_strength * mix(1.0, 1.35, motion_filter_boost);
    float sigma_normal = 0.42 * inv_strength * mix(1.0, 1.20, motion_filter_boost);
    float kernel_radius_signal = max(max(center_roughness, clamp(center_var / 4.0, 0.0, 1.0)), distance_kernel_bias);
    float outer_ring_weight = max(smoothstep(0.3, 0.7, kernel_radius_signal), motion_filter_boost * 0.55);
    uint iterations = clamp(params.atrous_iterations, 1u, 5u);
    uint motion_min_iterations = motion_filter_boost > 0.20 ? 3u : 1u;
    iterations = max(iterations, motion_min_iterations);

    vec3 filtered_color = center_color;
    vec3 scale_accumulated_color = vec3(0.0);
    float scale_accumulated_weight = 0.0;
    vec3 min_color = vec3(1.0e10);
    vec3 max_color = vec3(-1.0e10);
    float lum_sum = 0.0;
    float lum_sq_sum = 0.0;
    float neighborhood_count = 0.0;
    float normal_cone_min = 1.0;
    float max_relative_depth_delta = 0.0;
    float max_hit_distance_delta = 0.0;

    for (uint iter = 0u; iter < 5u; ++iter) {
        if (iter >= iterations) {
            break;
        }
        int step_width = int(1u << iter);
        vec3 pass_color = vec3(0.0);
        float pass_weight = 0.0;

        for (int ky = -2; ky <= 2; ++ky) {
            for (int kx = -2; kx <= 2; ++kx) {
                ivec2 sample_coords = coords + ivec2(kx * step_width, ky * step_width);
                if (sample_coords.x < 0 || sample_coords.x >= dims.x || sample_coords.y < 0 || sample_coords.y >= dims.y) {
                    continue;
                }

                uint sample_index = uint(sample_coords.y) * uint(dims.x) + uint(sample_coords.x);
#if RTV_DENOISER_SHARED_TILE
                vec3 sample_color;
                vec4 sample_dn;
                if (iter == 0u) {
                    ivec2 tile_coords = ivec2(gl_LocalInvocationID.xy) + ivec2(kx + DENOISER_TILE_RADIUS, ky + DENOISER_TILE_RADIUS);
                    int tile_index = denoiser_shared_index(tile_coords);
                    sample_color = shared_color_tile[tile_index].rgb;
                    sample_dn = decode_depth_normal(shared_depth_normal_tile[tile_index]);
                } else {
                    sample_color = imageLoad(input_color, sample_coords).rgb;
                    sample_dn = decode_depth_normal(input_depth_normal[sample_index]);
                }
#else
                vec3 sample_color = imageLoad(input_color, sample_coords).rgb;
                vec4 sample_dn = decode_depth_normal(input_depth_normal[sample_index]);
#endif
                PathDataRecord sample_path_data = path_data_buffer[sample_index];
                float sample_depth = sample_dn.r;
                vec3 sample_normal = sample_dn.gba;
                float sample_lum = luminance(sample_color);
                float sample_primary_hit_normalized = temporal_normalized_hit_distance(sample_path_data.direct_specular.a);
                float sample_secondary_hit_normalized = temporal_normalized_hit_distance(sample_path_data.indirect_specular.a);

                float kernel_w = atrous_kernel_weight(kx) * atrous_kernel_weight(ky);
                if (abs(kx) == 2 || abs(ky) == 2) {
                    kernel_w *= outer_ring_weight;
                }
                float color_diff = abs(sample_lum - center_lum);
                float color_w = exp(-color_diff / (sigma_color * (1.0 + float(iter) * 0.35) + 0.001));
                float depth_diff = abs(sample_depth - center_depth) / max(center_depth, 0.01);
                float depth_w = center_depth < 50.0 ? exp(-depth_diff / (sigma_depth + 0.001)) : 1.0;
                float normal_diff = 1.0 - clamp(dot(sample_normal, center_normal), -1.0, 1.0);
                float normal_w = center_depth < 50.0 ? exp(-normal_diff / (sigma_normal + 0.001)) : 1.0;
                float hit_distance_delta = max(
                    abs(sample_primary_hit_normalized - center_primary_hit_normalized),
                    abs(sample_secondary_hit_normalized - center_secondary_hit_normalized) * 0.5);
                float hit_distance_w = exp(-hit_distance_delta * mix(14.0, 5.0, center_primary_hit_normalized));
                float weight = kernel_w * color_w * depth_w * normal_w * hit_distance_w;

                pass_color += sample_color * weight;
                pass_weight += weight;
                min_color = min(min_color, sample_color);
                max_color = max(max_color, sample_color);
                lum_sum += sample_lum;
                lum_sq_sum += sample_lum * sample_lum;
                neighborhood_count += 1.0;

                if (is_surface_depth(center_depth) && is_surface_depth(sample_depth)) {
                    float sample_normal_dot = clamp(dot(sample_normal, center_normal), -1.0, 1.0);
                    normal_cone_min = min(normal_cone_min, sample_normal_dot);
                    max_relative_depth_delta = max(max_relative_depth_delta, depth_diff);
                    max_hit_distance_delta = max(max_hit_distance_delta, hit_distance_delta);
                }
            }
        }

        if (pass_weight > 0.0) {
            vec3 scale_color = pass_color / pass_weight;
            float scale_weight = 1.0 / (1.0 + float(iter) * 0.45);
            scale_accumulated_color += scale_color * scale_weight;
            scale_accumulated_weight += scale_weight;
        }
    }

    if (scale_accumulated_weight > 0.0) {
        filtered_color = scale_accumulated_color / scale_accumulated_weight;
    }

    float lum_mean = lum_sum / max(neighborhood_count, 1.0);
    float lum_variance = max(lum_sq_sum / max(neighborhood_count, 1.0) - lum_mean * lum_mean, 0.0);
    float lum_sigma = sqrt(lum_variance);

    bool sky_valid = !is_surface_depth(center_depth);
    vec3 wp = reconstruct_current_world_position(coords, center_depth, dims);
    vec2 surface_history_pos = sky_valid ? reproject_sky_history(coords, dims) : reproject_history(coords, wp, dims);
    vec2 velocity_history_pos = temporal_reproject_pixel(coords, velocity_pixels);
    bool velocity_on_screen = temporal_history_pixel_valid(velocity_history_pos, dims, 0.0);
    if (velocity_on_screen) {
        surface_history_pos = velocity_history_pos;
    }
    vec2 specular_history_pos = surface_history_pos;
    vec3 validation_wp = wp;
    float validation_hit_normalized = center_primary_hit_normalized;
    vec2 virtual_velocity_pixels = velocity_pixels;
    float virtual_motion_confidence = 0.0;
    if (!sky_valid && center_secondary_hit_distance > 0.001 && center_secondary_hit_distance < 65503.0) {
        vec3 view_dir = normalize(wp - prev_camera.current_pos.xyz);
        vec3 reflected_dir = normalize(reflect(view_dir, center_normal));
        float virtual_distance = clamp(center_secondary_hit_distance, 0.05, 512.0);
        vec3 virtual_wp = wp + reflected_dir * virtual_distance;
        vec2 current_virtual_pos = project_world_to_pixels(prev_camera.view_proj, virtual_wp, dims);
        vec2 previous_virtual_pos = project_world_to_pixels(prev_camera.prev_view_proj, virtual_wp, dims);
        vec2 candidate_virtual_velocity = current_virtual_pos - previous_virtual_pos;
        vec2 candidate_virtual_history_pos = vec2(coords) - candidate_virtual_velocity;
        bool virtual_history_on_screen = temporal_history_pixel_valid(candidate_virtual_history_pos, dims, 0.0);
        bool virtual_current_finite = current_virtual_pos.x >= -0.5 && current_virtual_pos.y >= -0.5;
        if (virtual_history_on_screen && virtual_current_finite) {
            virtual_motion_confidence = temporal_specular_virtual_motion_confidence(
                center_roughness,
                specular_signal,
                center_secondary_hit_normalized,
                length(velocity_pixels),
                length(candidate_virtual_velocity - velocity_pixels));
            specular_history_pos = mix(surface_history_pos, candidate_virtual_history_pos, virtual_motion_confidence);
            virtual_velocity_pixels = mix(velocity_pixels, candidate_virtual_velocity, virtual_motion_confidence);
            validation_wp = mix(wp, virtual_wp, virtual_motion_confidence);
            validation_hit_normalized = mix(
                center_primary_hit_normalized,
                temporal_normalized_hit_distance(length(virtual_wp - prev_camera.current_pos.xyz)),
                virtual_motion_confidence);
        }
    }
    vec2 history_pos = mix(surface_history_pos, specular_history_pos, specular_signal);
    bool on_screen = params.reset_history == 0u && temporal_history_pixel_valid(history_pos, dims, 0.0);
    bool diffuse_on_screen = params.reset_history == 0u && temporal_history_pixel_valid(surface_history_pos, dims, 0.0);
    bool specular_on_screen = params.reset_history == 0u && temporal_history_pixel_valid(specular_history_pos, dims, 0.0);
    vec2 history_sample_pos = on_screen ? history_pos : vec2(coords);
    vec2 diffuse_history_sample_pos = diffuse_on_screen ? surface_history_pos : vec2(coords);
    vec2 specular_history_sample_pos = specular_on_screen ? specular_history_pos : vec2(coords);

    float diffuse_signal = 1.0 - specular_signal;
    vec3 current_diffuse = filtered_color * diffuse_signal;
    vec3 current_specular = filtered_color - current_diffuse;
    bool reset_history = params.reset_history != 0u;
    vec3 diffuse_history_raw = reset_history ? vec3(0.0) : bilinear_diffuse_history_color(diffuse_history_sample_pos, dims);
    vec3 specular_history_raw = (!reset_history && specular_signal > 1.0e-4) ? bilinear_specular_history_color(specular_history_sample_pos, dims) : vec3(0.0);
    vec3 history_raw = reset_history ? vec3(0.0) : diffuse_history_raw + specular_history_raw;
    vec3 reprojected_wp = bilinear_prev_world(history_sample_pos, dims);
    float pos_diff = length(validation_wp - reprojected_wp);
    float validation_depth = mix(center_depth, length(validation_wp - prev_camera.current_pos.xyz), virtual_motion_confidence);
    float relative_pos_diff = pos_diff / max(validation_depth, 0.25);
    bool previous_sky_valid = reprojected_wp.y > 9.0e9;
    bool world_valid = is_surface_depth(center_depth) && !previous_sky_valid;
    bool history_kind_valid = sky_valid ? previous_sky_valid : world_valid;
    float base_disocclusion_confidence = sky_valid
        ? (on_screen && history_kind_valid ? 1.0 : 0.0)
        : temporal_disocclusion_confidence(
            on_screen,
            history_kind_valid,
            relative_pos_diff,
            normal_cone_min,
            max_relative_depth_delta);
    float history_primary_hit_normalized = world_valid
        ? temporal_normalized_hit_distance(length(reprojected_wp - prev_camera.prev_pos.xyz))
        : center_primary_hit_normalized;
    float hit_distance_confidence = sky_valid
        ? 1.0
        : temporal_hit_distance_confidence(
            validation_hit_normalized,
            history_primary_hit_normalized,
            mix(0.035, 0.085, validation_hit_normalized));
    hit_distance_confidence *= 1.0 - smoothstep(0.20, 0.55, max_hit_distance_delta);
    float hit_confidence = 1.0 - smoothstep(0.35, 0.85, max_hit_distance_delta);
    float diffuse_channel_confidence =
        (diffuse_on_screen ? 1.0 : 0.0) *
        base_disocclusion_confidence *
        mix(0.35, 1.0, hit_confidence);
    float specular_channel_confidence = base_disocclusion_confidence *
        (specular_on_screen ? 1.0 : 0.0) *
        hit_distance_confidence *
        (1.0 - smoothstep(0.55, 0.92, center_roughness));
    float mirror_strength = 1.0 - smoothstep(0.05, 0.25, center_roughness);
    float mirror_floor = mix(0.15, 0.45, center_roughness);
    specular_channel_confidence = max(specular_channel_confidence, mirror_floor);
    float disocclusion_confidence = mix(diffuse_channel_confidence, specular_channel_confidence, specular_signal);

    float history_lum_before_clip = luminance(history_raw);
    vec3 diffuse_history = temporal_clamp_history_ycocg(
        diffuse_history_raw,
        min_color * diffuse_signal,
        max_color * diffuse_signal,
        lum_sigma * max(diffuse_signal, 0.1));
    vec3 specular_history = temporal_clamp_history_ycocg(
        specular_history_raw,
        min_color * specular_signal,
        max_color * specular_signal,
        lum_sigma * max(specular_signal, 0.1) * 0.80);
    vec3 specular_firefly_clamp = specular_history * 8.0 + 4.0;
    current_specular = min(current_specular, specular_firefly_clamp);
    vec3 history = diffuse_history + specular_history;
    float history_lum_after_clip = luminance(history);
    float lum_delta = abs(history_lum_before_clip - center_lum) / (max(center_lum, history_lum_before_clip) + 0.02);
    float clipped_lum_delta = abs(history_lum_before_clip - history_lum_after_clip) / (history_lum_before_clip + 0.02);
    float neighborhood_lum_delta = abs(history_lum_before_clip - lum_mean) / (lum_mean + lum_sigma + 0.02);
    float reactive_mask = temporal_reactive_weight(lum_delta, clipped_lum_delta, neighborhood_lum_delta);

    vec2 m_dd = imageLoad(direct_diffuse_moments, coords).rg;
    vec2 m_ds = imageLoad(direct_specular_moments, coords).rg;
    vec2 m_id = imageLoad(indirect_diffuse_moments, coords).rg;
    vec2 m_is = imageLoad(indirect_specular_moments, coords).rg;
    uvec4 hl = imageLoad(history_length, coords);
    uint n_is = hl.a & 0x7FFFu;
    bool moment_valid = (hl.a & 0x8000u) != 0u;

    float diffuse_mean_lum = m_dd.x * path_data.direct_diffuse.a + m_id.x * path_data.indirect_diffuse.a;
    float specular_mean_lum = m_ds.x * path_data.direct_specular.a + m_is.x * path_data.indirect_specular.a;
    float diffuse_var = m_dd.y + m_id.y;
    float specular_var = m_ds.y + m_is.y;

    float diffuse_cv = sqrt(max(diffuse_var, 0.0)) / (max(diffuse_mean_lum, 0.01));
    float specular_cv = sqrt(max(specular_var, 0.0)) / (max(specular_mean_lum, 0.01));
    float diffuse_confidence = exp(-diffuse_cv * 4.0);
    float specular_confidence = exp(-specular_cv * 6.0);
    float confidence = exp(-sqrt(max(center_var, 0.0)) * 4.0);

    float diffuse_motion_confidence = temporal_motion_confidence(velocity_pixels, 30.0, 0.45);
    float specular_motion_confidence = temporal_motion_confidence(virtual_velocity_pixels, 16.0, 0.18);
    float motion_confidence = mix(diffuse_motion_confidence, specular_motion_confidence, specular_signal);
    float specular_rejection = 1.0 - reactive_mask * mix(0.65, 0.95, confidence);

    float diffuse_hl = float(hl.x + hl.z) * 0.5;
    float specular_hl = float(hl.y + n_is) * 0.5;
    float diffuse_frame_blend = params.reset_history != 0u ? 0.0 : clamp(diffuse_hl / 30.0, 0.0, 1.0);
    float specular_frame_blend = params.reset_history != 0u ? 0.0 : clamp(specular_hl / 30.0, 0.0, 1.0);

    float diffuse_history_weight = temporal_history_weight(
        diffuse_confidence,
        diffuse_channel_confidence,
        diffuse_motion_confidence,
        reactive_mask * 0.45,
        diffuse_frame_blend);
    float specular_history_weight = temporal_history_weight(
        specular_confidence,
        specular_channel_confidence,
        specular_motion_confidence,
        reactive_mask,
        specular_frame_blend);
    float diffuse_motion_history_floor = motion_history_available *
        diffuse_channel_confidence *
        diffuse_frame_blend *
        (1.0 - reactive_mask * 0.35) *
        mix(0.28, 0.46, diffuse_confidence);
    float specular_motion_history_floor = motion_history_available *
        specular_channel_confidence *
        specular_frame_blend *
        (1.0 - reactive_mask * 0.60) *
        mix(0.10, 0.26, specular_confidence);
    diffuse_history_weight = min(max(diffuse_history_weight, diffuse_motion_history_floor), 0.90);
    specular_history_weight = min(max(specular_history_weight, specular_motion_history_floor), 0.78);
    specular_history_weight = mix(
        specular_history_weight,
        max(specular_history_weight, 0.35),
        mirror_strength);
    float history_weight = mix(diffuse_history_weight, specular_history_weight, specular_signal);
    float denoiser_rejection = 1.0 - clamp(disocclusion_confidence * motion_confidence * specular_rejection, 0.0, 1.0);
    vec3 resolved_diffuse = mix(current_diffuse, diffuse_history, diffuse_history_weight);
    vec3 resolved_specular = mix(current_specular, specular_history, specular_history_weight);
    vec3 resolved_color = resolved_diffuse + resolved_specular;
    float emissive_history_confidence = diffuse_channel_confidence *
        diffuse_motion_confidence *
        diffuse_frame_blend *
        (1.0 - reactive_mask);
    float emissive_spike = smoothstep(lum_mean + lum_sigma * 1.5 + 0.15, lum_mean + lum_sigma * 5.0 + 0.5, center_lum);
    float emissive_clamp_amount = emissive_signal * emissive_spike * emissive_history_confidence;
    float resolved_lum = luminance(resolved_color);
    float emissive_history_lum = max(luminance(diffuse_history), luminance(history));
    float emissive_lum_limit = max(lum_mean + lum_sigma * 2.5 + 0.05, emissive_history_lum * 1.75 + 0.25);
    vec3 emissive_clamped_color = resolved_color * min(1.0, emissive_lum_limit / max(resolved_lum, 1.0e-4));
    resolved_color = mix(resolved_color, emissive_clamped_color, emissive_clamp_amount);
    resolved_diffuse = mix(resolved_diffuse, resolved_color * diffuse_signal, emissive_clamp_amount);
    resolved_specular = resolved_color - resolved_diffuse;

    float reprojection_confidence = base_disocclusion_confidence;

    vec3 debug_color = filtered_color;
    if (params.debug_view == 1u) {
        debug_color = vec3(center_var / 4.0);
    } else if (params.debug_view == 2u) {
        debug_color = center_normal * 0.5 + 0.5;
    } else if (params.debug_view == 3u) {
        debug_color = vec3(1.0 - reprojection_confidence, reprojection_confidence, 0.0);
    } else if (params.debug_view == 4u) {
        debug_color = vec3(denoiser_rejection, 1.0 - denoiser_rejection, 0.0);
    } else if (params.debug_view == 28u) {
        vec2 visual_velocity = clamp(velocity_pixels / 32.0, vec2(-1.0), vec2(1.0));
        debug_color = vec3(visual_velocity * 0.5 + vec2(0.5), clamp(length(velocity_pixels) / 32.0, 0.0, 1.0));
    } else if (params.debug_view == 33u) {
        debug_color = vec3(reactive_mask, 1.0 - reactive_mask, 0.0);
    } else if (params.debug_view == 34u) {
        debug_color = vec3(history_weight);
    } else if (params.debug_view == 47u) {
        debug_color = path_data.direct_diffuse.rgb;
    } else if (params.debug_view == 48u) {
        debug_color = path_data.direct_specular.rgb;
    } else if (params.debug_view == 49u) {
        debug_color = path_data.indirect_diffuse.rgb;
    } else if (params.debug_view == 50u) {
        debug_color = path_data.indirect_specular.rgb;
    } else if (params.debug_view == 51u) {
        debug_color = path_data.albedo_roughness_hit_confidence.rgb;
    } else if (params.debug_view == 52u) {
        debug_color = vec3(
            clamp(path_data.albedo_roughness_hit_confidence.w, 0.0, 1.0),
            center_primary_hit_normalized,
            center_secondary_hit_normalized);
    } else if (params.debug_view == 53u) {
        debug_color = vec3(outer_ring_weight);
    } else if (params.debug_view == 54u) {
        debug_color = vec3(
            center_primary_hit_normalized,
            center_secondary_hit_normalized,
            hit_distance_confidence);
    } else if (params.debug_view == 55u) {
        vec2 visual_virtual_velocity = clamp(virtual_velocity_pixels / 32.0, vec2(-1.0), vec2(1.0));
        debug_color = vec3(
            visual_virtual_velocity * 0.5 + vec2(0.5),
            virtual_motion_confidence);
    } else if (params.debug_view == 56u) {
        debug_color = vec3(
            temporal_effective_history_length(diffuse_history_weight) / 50.0,
            diffuse_channel_confidence,
            diffuse_signal);
    } else if (params.debug_view == 57u) {
        debug_color = vec3(
            temporal_effective_history_length(specular_history_weight) / 50.0,
            specular_channel_confidence,
            specular_signal);
    } else if (params.debug_view == 58u) {
        debug_color = vec3(
            emissive_signal,
            emissive_history_confidence,
            emissive_clamp_amount);
    } else if (params.debug_view == 59u) {
        debug_color = vec3(diffuse_confidence);
    } else if (params.debug_view == 60u) {
        debug_color = vec3(diffuse_channel_confidence);
    } else if (params.debug_view == 61u) {
        debug_color = vec3(diffuse_frame_blend);
    } else if (params.debug_view == 62u) {
        debug_color = vec3(max_hit_distance_delta);
    } else if (params.debug_view == 63u) {
        debug_color = vec3(diffuse_on_screen ? 1.0 : 0.0);
    } else if (params.debug_view == 64u) {
        debug_color = vec3(base_disocclusion_confidence);
    } else if (params.debug_view == 65u) {
        debug_color = vec3(specular_channel_confidence);
    } else if (params.debug_view == 66u) {
        debug_color = vec3(specular_history_weight);
    } else if (params.debug_view == 74u) {
        debug_color = vec3(m_dd.y / (m_dd.x * m_dd.x + 0.01));
    } else if (params.debug_view == 75u) {
        debug_color = vec3(m_ds.y / (m_ds.x * m_ds.x + 0.01));
    } else if (params.debug_view == 76u) {
        debug_color = vec3(m_id.y / (m_id.x * m_id.x + 0.01));
    } else if (params.debug_view == 77u) {
        debug_color = vec3(m_is.y / (m_is.x * m_is.x + 0.01));
    } else if (params.debug_view == 78u) {
        debug_color = vec3(diffuse_hl / 64.0);
    } else if (params.debug_view == 79u) {
        debug_color = vec3(specular_hl / 64.0);
    } else if (params.debug_view == 80u) {
        debug_color = vec3(moment_valid ? 1.0 : 0.0);
    } else if (params.debug_view == 81u) {
        vec4 md = imageLoad(moment_debug, coords);
        debug_color = vec3(md.r);
    } else if (params.debug_view == 82u) {
        vec4 md = imageLoad(moment_debug, coords);
        debug_color = vec3(md.g);
    } else if (params.debug_view == 83u) {
        vec4 md = imageLoad(moment_debug, coords);
        debug_color = vec3(md.b);
    } else if (params.debug_view == 84u) {
        vec4 md = imageLoad(moment_debug, coords);
        debug_color = vec3(md.a);
    } else if (params.debug_view == 85u) {
        debug_color = vec3(diffuse_history_weight);
    } else if (params.debug_view == 86u) {
        debug_color = vec3(specular_history_weight);
    } else if (params.debug_view == 87u) {
        debug_color = vec3(diffuse_var);
    } else if (params.debug_view == 88u) {
        debug_color = vec3(specular_var);
    }

    vec3 denoised = params.debug_view == 0u ? resolved_color : debug_color;
    imageStore(output_diffuse_history, coords, vec4(resolved_diffuse, 1.0));
    imageStore(output_specular_history, coords, vec4(resolved_specular, 1.0));
    imageStore(output_denoised, coords, vec4(denoised, 1.0));
}
